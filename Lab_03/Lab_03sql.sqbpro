CREATE TABLE BONUS (
    ENAME TEXT,
    JOB TEXT,
    SAL REAL,
    COMM REAL
);

EMP TABLE
CREATE TABLE EMP (
    EMPNO INTEGER NOT NULL,
    ENAME TEXT,
    JOB TEXT,
    MGR INTEGER,
    HIREDATE TEXT,
    SAL REAL,
    COMM REAL,
    DEPTNO INTEGER
);

